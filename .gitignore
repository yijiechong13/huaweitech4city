__pycache__/
.DS_Store

# pipeline/ -- training data stays local-only (large, not needed to serve).
# checkpoints/ is deliberately NOT ignored -- committed to git (a few MB),
# so Render's build has them without a separate fetch/LFS step.
pipeline/dataset/
pipeline/preprocess/test_pipeline.py

# backend/ -- local embedding cache, secrets, and its virtualenv
backend/data/
backend/.env
backend/.venv/

# frontend/ and supabase/ have their own .gitignore (node_modules, dist,
# .env*, Supabase CLI's .branches/.temp) -- not duplicated here.
