# The only .env.example in this repo. frontend/ and backend/ each need
# their own .env file (Vite and pydantic-settings both read from their own
# service directory, not the repo root) -- copy the relevant lines below
# into frontend/.env and backend/.env respectively. See docs/frontend.md
# and docs/backend.md for what each variable does.

# --- frontend/.env ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- backend/.env ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=your-anthropic-key
BACKEND_SHARED_SECRET=change-me
ALLOWED_ORIGINS=http://localhost:5173
# CHECKPOINT_PATH=/absolute/path/to/message_graph_sage.pt
# EMBEDDING_DB_PATH=/absolute/path/to/embeddings.sqlite3

# --- supabase secrets (set via `supabase secrets set`, not a .env file) ---
# BACKEND_URL=https://your-backend-host
# BACKEND_SHARED_SECRET=change-me   (must match backend/.env's value)
